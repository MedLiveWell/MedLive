# Copy to .env.local and fill in the values for local development.
# In production, set these on the hosting platform (Vercel, etc).

# Public site URL — used by sitemap, robots, Schema.org and metadata.
# Must include scheme and host (and www if applicable). No trailing slash.
NEXT_PUBLIC_SITE_URL=

# Google Analytics 4 measurement ID (G-XXXXXXXXXX). Leave blank to disable.
NEXT_PUBLIC_GA_ID=

# RD Station Marketing — Conversions API tokens.
# Get them at https://app.rdstation.com.br/integracoes/tokens
RD_STATION_PUBLIC_TOKEN=
RD_STATION_PRIVATE_TOKEN=
